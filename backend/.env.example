# Finance Tracker — Environment Configuration
# Copy this file to .env and adjust as needed.
# The install script does this automatically.

# ── Ollama (local AI) ──────────────────────────────────────────────────────
# LLM used for transaction categorization
OLLAMA_MODEL=qwen2.5:7b

# Embedding model used for vector similarity search
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Ollama service URL — change only if Ollama runs on a non-default port
# OLLAMA_HOST=http://localhost:11434

# ── Optional tuning ────────────────────────────────────────────────────────
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# Minimum confidence score for auto-categorization (0.0–1.0)
# MIN_CONFIDENCE_SCORE=0.75

# How many days to look back when deduplicating transactions
# DEDUP_WINDOW_DAYS=3
